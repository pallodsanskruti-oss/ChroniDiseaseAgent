# ── IBM Cloud / Watsonx.ai Credentials ──────────────────────────────────────
# Required: Get your API key from IBM Cloud → Manage → IAM → API Keys
IBM_API_KEY=your_ibm_api_key_here

# Required: Keep as-is for us-south region
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Required: Get from Watsonx.ai project settings
IBM_WATSONX_PROJECT_ID=your_project_id_here

# Optional: Only needed if you use a Deployment Space instead of a Project
IBM_WATSONX_SPACE_ID=

# ── Flask Configuration ───────────────────────────────────────────────────────
# CHANGE THIS in production — use a long random string
FLASK_SECRET_KEY=change_this_to_a_random_string_in_production
FLASK_DEBUG=False

# ── App Settings ──────────────────────────────────────────────────────────────
APP_PORT=5000
APP_HOST=0.0.0.0
